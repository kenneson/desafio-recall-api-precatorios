# Banco local padrao usado pela aplicacao.
DATABASE_URL=sqlite:///data/app.db

# Integracao opcional com LLM. Mantenha desligada para executar apenas o parser deterministico ou ligada para integracao com LLM.
LLM_ENABLED=false
GROQ_API_KEY=
LLM_API_KEY=
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=30
LLM_CONFIDENCE_THRESHOLD=0.75
